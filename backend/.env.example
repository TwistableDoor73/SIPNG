# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sipng_dev"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sipng_dev
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# API Gateway
API_GATEWAY_PORT=3000
USER_SERVICE_URL=http://localhost:3001
TICKETS_SERVICE_URL=http://localhost:3002
GROUPS_SERVICE_URL=http://localhost:3003

# Ports
USER_SERVICE_PORT=3001
TICKETS_SERVICE_PORT=3002
GROUPS_SERVICE_PORT=3003

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:4200,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
