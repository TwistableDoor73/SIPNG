{
  "version": "v7",
  "services": {
    "api": {
      "source": "./backend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm start",
      "envVars": {
        "NODE_ENV": "production",
        "PORT": "3000"
      }
    },
    "postgres": {
      "type": "postgres"
    }
  }
}